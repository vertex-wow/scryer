{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "node",
      "args": ["esbuild.mjs"],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "watch",
      "type": "shell",
      "command": "node",
      "args": ["esbuild.mjs", "--watch"],
      "isBackground": true,
      "group": "build",
      "presentation": { "reveal": "never" },
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^ERROR (.+)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^> node esbuild\\.mjs",
          "endsPattern": "^Watching"
        }
      }
    }
  ]
}
