{
  "env": {
    "DISABLE_TELEMETRY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(chmod *)",
      "Bash(gh api *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr view *)",
      "Bash(gh release *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git pull *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(xargs *)",
      "Bash(tail *)",
      "Edit",
      "Grep",
      "Read",
      "Task",
      "WebFetch",
      "WebSearch",
      "Read(//tmp/**)",
      "Bash(sort *)",
      "Bash(pnpm test *)",
      "Bash(pnpm typecheck *)",
      "Bash(rustydemon-cli *)",
      "Bash(~/.cargo/bin/rustydemon-cli *)",
      "Bash(cargo search *)",
      "Bash(pnpm build *)",
      "Bash(shellcheck *)",
      "Bash(pnpm bench *)",
      "Bash(node dist/bench.js)",
      "Bash(node dev/bench.build.mjs)",
      "Bash(node dist/conv-time.js)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(mkdir -p /tmp/*)",
      "Bash(npm show *)",
      "Bash(pnpm run *)",
      "Bash(find *)",
      "Bash(npx jest *)"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "deny": [],
  "ask": [
    "Skill(caveman-commit)",
    "Skill(caveman-commit:*)",
    "Bash(git add:*)",
    "Bash(git commit:*)",
    "Bash(git -C:*)"
  ],
  "defaultMode": "default"
}
