{
  "_comment": "Copy this file to dev/settings.local.json and fill in your local paths. It is gitignored. Keys that match a scryer.* VS Code setting use the exact same name — you can symlink your VS Code settings.json here if desired.",

  "_comment: scryer.installDir": "Mandatory. Path to your World of Warcraft installation minus flavor directory.",
  "scryer.installDir": "/path/to/World of Warcraft/",

  "_comment: wowAccount": "dev scripts only. Mandatory for dev/links.ts. Your WoW account name, used to locate WTF/Account/<name>.",
  "wowAccount": "youraccountname",

  "_comment: scryer.cacheLocation": "Ignored by scripts. Where Scryer stores its cache. Default: global. Options: global, workspace, custom.",
  "scryer.cacheLocation": "global",

  "_comment: scryer.cacheDir": "Mandatory for tests and scripts. Cache root when cacheLocation is 'custom'. Also used by CASC test layers (pnpm test:xml-casc, pnpm test:toc-casc) to locate <cacheDir>/<flavor>/source — set this to enable those tests.",
  "scryer.cacheDir": "",

  "_comment: scryer.grepPath": "Path to grep for listfile filtering. Omit to auto-detect from PATH. On Windows, install via Git for Windows or MSYS2.",
  "scryer.grepPath": "",

  "_comment: scryer.rsvgConvertPath": "Path to rsvg-convert for SVG→PNG conversion during workspace pre-warm. Omit to auto-detect from PATH (install librsvg2-bin on Linux/macOS).",
  "scryer.rsvgConvertPath": "",

  "_comment: scryer.imageConvertPath": "Path to gm (GraphicsMagick) or convert (ImageMagick) for PNG→TGA conversion during workspace pre-warm. Omit to auto-detect from PATH.",
  "scryer.imageConvertPath": "",

  "_comment: scryer.flavorConfigPath": "Path to a JSON override file for per-flavor display defaults. Omit to use built-ins.",
  "scryer.flavorConfigPath": "",

  "_comment: scryer.flavor": "WoW flavor for extraction. Default: retail. Options: retail, classic, classic_era.",
  "scryer.flavor": "retail",

  "_comment: scryer.defaultTarget": "Default WoW version target. Default: mainline. Options: mainline, mists, bcc, classic_era.",
  "scryer.defaultTarget": "mainline",

  "_comment: scryer.locale": "WoW locale returned by GetLocale(). Default: enUS.",
  "scryer.locale": "enUS",

  "_comment: scryer.screenResolution": "Physical monitor resolution for the preview. Default: 1920x1080.",
  "scryer.screenResolution": "1920x1080",

  "_comment: scryer.startupContent": "Blizzard content loaded at activation. Default: all-templates-shared-textures.",
  "scryer.startupContent": "all-templates-shared-textures",

  "_comment: scryer.userAddonPreload": "Texture pre-warm strategy. Default: current-file.",
  "scryer.userAddonPreload": "current-file",

  "_comment: scryer.showRuler": "Show pixel ruler overlay in the preview panel. Default: true.",
  "scryer.showRuler": true
}
