<Ui xmlns="http://www.blizzard.com/wow/ui/"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://www.blizzard.com/wow/ui/
   https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/FrameXML/UI.xsd">

  <!--
    test_texcoords.xml  -  TexCoords sprite-sheet slicing diagnostic
    Sprite sheet: Interface\Buttons\UI-Silver-Button-Up (same as UIMenuButtonStretchTemplate)

    Layout (top row = full sheet reference, bottom rows = individual slices):

      [Full sheet 128x64]   [TopLeft 12x6]  [TopRight 12x6]
                            [BotLeft 12x6]  [BotRight 12x6]

    Each slice is the exact same TexCoords used by UIMenuButtonStretchTemplate corners.
    With correct slicing, each frame should show only its 12x6 region of the sheet.
    With broken slicing, the textures will be offset or invisible.
  -->

  <!-- Full sprite sheet for reference (no TexCoords - show the whole thing) -->
  <Frame name="FullSheet" parent="UIParent">
    <Size x="128" y="64"/>
    <Anchors>
      <Anchor point="TOPLEFT" x="20" y="-20"/>
    </Anchors>
    <Layers>
      <Layer level="BACKGROUND">
        <Texture file="Interface\Buttons\UI-Silver-Button-Up">
          <Anchors><Anchor point="TOPLEFT"/><Anchor point="BOTTOMRIGHT"/></Anchors>
        </Texture>
      </Layer>
    </Layers>
  </Frame>

  <!-- TopLeft corner slice  (left=0, right=0.09375, top=0, bottom=0.1875) -->
  <Frame name="SliceTopLeft" parent="UIParent">
    <Size x="48" y="24"/>
    <Anchors>
      <Anchor point="TOPLEFT" x="20" y="-100"/>
    </Anchors>
    <Layers>
      <Layer level="BACKGROUND">
        <Texture file="Interface\Buttons\UI-Silver-Button-Up">
          <Anchors><Anchor point="TOPLEFT"/><Anchor point="BOTTOMRIGHT"/></Anchors>
          <TexCoords left="0" right="0.09375" top="0" bottom="0.1875"/>
        </Texture>
      </Layer>
    </Layers>
  </Frame>

  <!-- TopRight corner slice  (left=0.53125, right=0.625, top=0, bottom=0.1875) -->
  <Frame name="SliceTopRight" parent="UIParent">
    <Size x="48" y="24"/>
    <Anchors>
      <Anchor point="TOPLEFT" x="80" y="-100"/>
    </Anchors>
    <Layers>
      <Layer level="BACKGROUND">
        <Texture file="Interface\Buttons\UI-Silver-Button-Up">
          <Anchors><Anchor point="TOPLEFT"/><Anchor point="BOTTOMRIGHT"/></Anchors>
          <TexCoords left="0.53125" right="0.625" top="0" bottom="0.1875"/>
        </Texture>
      </Layer>
    </Layers>
  </Frame>

  <!-- BottomLeft corner slice  (left=0, right=0.09375, top=0.625, bottom=0.8125) -->
  <Frame name="SliceBottomLeft" parent="UIParent">
    <Size x="48" y="24"/>
    <Anchors>
      <Anchor point="TOPLEFT" x="20" y="-140"/>
    </Anchors>
    <Layers>
      <Layer level="BACKGROUND">
        <Texture file="Interface\Buttons\UI-Silver-Button-Up">
          <Anchors><Anchor point="TOPLEFT"/><Anchor point="BOTTOMRIGHT"/></Anchors>
          <TexCoords left="0" right="0.09375" top="0.625" bottom="0.8125"/>
        </Texture>
      </Layer>
    </Layers>
  </Frame>

  <!-- BottomRight corner slice  (left=0.53125, right=0.625, top=0.625, bottom=0.8125) -->
  <Frame name="SliceBottomRight" parent="UIParent">
    <Size x="48" y="24"/>
    <Anchors>
      <Anchor point="TOPLEFT" x="80" y="-140"/>
    </Anchors>
    <Layers>
      <Layer level="BACKGROUND">
        <Texture file="Interface\Buttons\UI-Silver-Button-Up">
          <Anchors><Anchor point="TOPLEFT"/><Anchor point="BOTTOMRIGHT"/></Anchors>
          <TexCoords left="0.53125" right="0.625" top="0.625" bottom="0.8125"/>
        </Texture>
      </Layer>
    </Layers>
  </Frame>

</Ui>
