<Ui xmlns="http://www.blizzard.com/wow/ui/">

  <!--
    direct_texture_casc.xml
    Pipeline e2e test — requires CASC extraction.
    Set extractedAssetsDir in dev/config.local.json; test skips automatically if absent.

    ARTWORK: Interface\Tooltips\Tooltip  (BLP decode from extracted assets)
  -->
  <Frame name="TextureTestFrame" parent="UIParent" frameStrata="MEDIUM">
    <Size x="64" y="64"/>
    <Anchors>
      <Anchor point="CENTER"/>
    </Anchors>
    <Layers>
      <Layer level="ARTWORK">
        <Texture setAllPoints="true" file="Interface\Tooltips\Tooltip"/>
      </Layer>
    </Layers>
  </Frame>

</Ui>
