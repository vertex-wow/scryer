<Ui xmlns="http://www.blizzard.com/wow/ui/"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://www.blizzard.com/wow/ui/
   https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/FrameXML/UI.xsd">

  <Frame name="MixinExampleFrame" mixin="MixinExampleFrameMixin" parent="UIParent">
    <Size x="300" y="180"/>
    <Anchors>
      <Anchor point="CENTER"/>
    </Anchors>
    <Layers>
      <Layer level="BACKGROUND">
        <Texture>
          <Anchors>
            <Anchor point="TOPLEFT"/>
            <Anchor point="BOTTOMRIGHT"/>
          </Anchors>
          <Color r="0.08" g="0.08" b="0.12" a="0.95"/>
        </Texture>
      </Layer>
      <Layer level="ARTWORK">
        <FontString parentKey="TitleText" inherits="GameFontNormal"
                    text="(mixin not applied)">
          <Anchors>
            <Anchor point="CENTER"/>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <Scripts>
      <OnLoad>
        Mixin(self, MixinExampleFrameMixin)
        self:OnLoad()
      </OnLoad>
    </Scripts>
  </Frame>

</Ui>
